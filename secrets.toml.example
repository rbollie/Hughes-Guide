# Copy this file to secrets.toml and fill in your real values.
# secrets.toml is gitignored — never commit it.
# On Streamlit Cloud, configure these in the app dashboard under "Secrets".

# Required for Document Analysis tab
ANTHROPIC_API_KEY = "sk-ant-your-key-here"

# Optional — if both are set, Hughes Guide uses Supabase for durable storage.
# If either is empty, the app falls back to a local SQLite file (ephemeral on Streamlit Cloud).
# Get these from Supabase: Project Settings → API.
# Use the SERVICE ROLE key (not the anon key) so the app has full read/write access.
SUPABASE_URL = ""
SUPABASE_KEY = ""
